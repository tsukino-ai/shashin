<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const closeSVG = '<svg aria-hidden="true" class="pswp__icn" viewBox="0 0 32 32" width="32" height="32"><path d="M8 8l16 16M24 8L8 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>';
  const arrowSVG = '<svg aria-hidden="true" class="pswp__icn" viewBox="0 0 32 32" width="32" height="32"><path d="M20 6L10 16l10 10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>';

  function initPhotoSwipe() {
    const gallery = document.getElementById('gallery');
    if (!gallery) return;

    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',
      pswpModule: () => import('photoswipe'),
      mainClass: 'pswp--custom-theme',
      bgOpacity: 0.96,
      showHideAnimationType: 'zoom',
      showAnimationDuration: 500,
      hideAnimationDuration: 400,
      zoomAnimationDuration: 300,
      closeSVG,
      arrowPrevSVG: arrowSVG,
      arrowNextSVG: arrowSVG,
      padding: { top: 20, bottom: 80, left: 20, right: 20 },
    });

    // Register custom caption
    lightbox.on('uiRegister', function () {
      lightbox.pswp.ui.registerElement({
        name: 'custom-caption',
        order: 9,
        isButton: false,
        appendTo: 'root',
        html: '',
        onInit: (el, pswp) => {
          lightbox.pswp.on('change', () => {
            const currSlide = lightbox.pswp.currSlide;
            if (!currSlide || !currSlide.data) {
              el.innerHTML = '';
              return;
            }
            const elData = currSlide.data.element;
            let captionHTML = '';
            if (elData) {
              const caption = elData.getAttribute('data-caption');
              if (caption) captionHTML = caption;
            }
            el.innerHTML = captionHTML ? `<div class="pswp__caption-inner">${captionHTML}</div>` : '';
          });
        },
      });
    });

    // Dynamic easing: ease-out-back for open, ease-in-out for zoom, ease-in-back for close
    const backEasing = {
      out: 'cubic-bezier(0.34, 1.56, 0.64, 1)',
      inOut: 'cubic-bezier(0.68, -0.55, 0.265, 1.55)',
      in: 'cubic-bezier(0.32, 0, 0.67, 0)',
    };
    lightbox.on('firstUpdate', () => {
      lightbox.pswp.options.easing = backEasing.out;
    });
    lightbox.on('initialZoomInEnd', () => {
      lightbox.pswp.options.easing = backEasing.inOut;
    });
    lightbox.on('close', () => {
      lightbox.pswp.options.easing = backEasing.in;
    });

    // Fix aspect ratio: override declared dimensions with actual image dimensions
    lightbox.on('change', () => {
      const slide = lightbox.pswp.currSlide;
      if (!slide || !slide.content || !slide.content.element) return;
      const img = slide.content.element;
      const applyRealSize = () => {
        if (!img.naturalWidth || !img.naturalHeight) return;
        const realW = img.naturalWidth;
        const realH = img.naturalHeight;
        // Only update if actual size differs from declared size
        if (slide.width !== realW || slide.height !== realH) {
          slide.width = realW;
          slide.height = realH;
          slide.content.width = realW;
          slide.content.height = realH;
          if (slide.content.setDisplayedSize) {
            slide.content.setDisplayedSize(realW, realH);
          }
          if (slide.calculateSize) {
            slide.calculateSize();
          }
          if (slide.isActive && lightbox.pswp.updateSize) {
            lightbox.pswp.updateSize(true);
          }
        }
      };
      if (img.complete) {
        applyRealSize();
      } else {
        img.addEventListener('load', applyRealSize, { once: true });
      }
    });

    lightbox.init();
    return lightbox;
  }

  let lightbox = initPhotoSwipe();

  document.addEventListener('astro:page-load', () => {
    if (lightbox) {
      lightbox.destroy();
    }
    lightbox = initPhotoSwipe();
  });
</script>

