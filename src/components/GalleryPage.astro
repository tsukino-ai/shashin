---
import { env } from 'cloudflare:workers';
import Layout from '../layouts/Layout.astro';
import PhotoGrid from './PhotoGrid.astro';

export interface Props {
  title: string;
  heading: string;
  prefix: string;
}

const { title, heading, prefix } = Astro.props;

const bucket = env.GALARY_BUCKET;

let photos: { src: string; thumb: string; w: number; h: number }[] = [];
let error: string | null = null;

try {
  const listed = await bucket.list({ prefix });
  photos = listed.objects.map((obj) => {
    const publicUrl = `https://cdn.tsukino.dev/${obj.key}`;
    return {
      src: publicUrl,
      thumb: publicUrl,
      w: 2000,
      h: 3000,
    };
  });
} catch (e) {
  console.error('R2 list error:', e);
  error = '无法加载照片，请稍后重试';
}
---

<Layout title={title}>
  <h1 class="text-3xl font-light mb-8">{heading}</h1>
  {error && <p class="text-red-400 text-center py-8">{error}</p>}
  <PhotoGrid photos={photos} />
</Layout>
