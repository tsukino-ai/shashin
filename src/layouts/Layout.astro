---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body class="bg-neutral-900 text-white min-h-screen">
  <nav class="px-6 py-4 border-b border-neutral-800 flex gap-6">
    <a href="/" class="hover:text-neutral-300 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded">精选</a>
    <a href="/private" class="hover:text-neutral-300 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded">写真集</a>
    <a href="/upload" class="hover:text-neutral-300 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded">上传</a>
  </nav>
  <main class="max-w-7xl mx-auto px-6 py-8">
    <slot />
  </main>
</body>
</html>
